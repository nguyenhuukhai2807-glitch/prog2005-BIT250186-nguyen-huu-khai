def selection_sort(arr):
    a = len(arr)
    for i in range(a):
        max_index = 1
        for j in range(i+1, a):
            if arr[j] > arr[max_index]:
                max_index = j
    arr[i], arr[max_index] = arr[max_index], arr[i]

arr = [1, 2, 3, 4, 5]
selection_sort(arr)
print("selection_sort", arr)
